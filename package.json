{
  "name": "@dotrino/identity",
  "version": "0.19.1",
  "description": "Identidad y rating de usuarios compartidos entre apps de Dotrino (vault iframe + postMessage)",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./node": {
      "import": "./src/node.js"
    },
    "./capabilities": {
      "import": "./vault/capabilities.js"
    },
    "./vault/core.js": "./vault/core.js"
  },
  "files": [
    "src",
    "vault",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "identity",
    "rating",
    "dotrino",
    "vault",
    "cross-origin"
  ],
  "author": "seyacat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imdotrino/dotrino-identity.git"
  },
  "dependencies": {
    "@dotrino/proxy-client": "0.6.3"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5"
  }
}
